{
  "name": "@impri/mcp",
  "version": "0.1.0",
  "description": "Impri MCP server — human-in-the-loop approval inbox for AI agents",
  "keywords": ["mcp", "impri", "human-in-the-loop", "approval", "ai-agent"],
  "license": "MIT",
  "author": "Radim Sekera",
  "homepage": "https://impri.dev",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/sekera.radim/impri.git",
    "directory": "mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./webhook": "./dist/webhook.js"
  },
  "bin": {
    "impri-mcp": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src test",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
