{
  "name": "@impri/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "deploy:cloud": "VITE_API_BASE=https://api.impri.dev/v1 vite build && npx wrangler pages deploy dist --project-name=impri-app --branch main --commit-dirty=true",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "dompurify": "^3.2.6",
    "marked": "^14.1.4",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "vue": "^3.5.16",
    "vuetify": "^3.8.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.1.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  }
}
