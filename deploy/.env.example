# Impri production environment variables
# Copy this file to deploy/.env and fill in the values.
#
# Never commit deploy/.env to git — it contains secrets.
# Generate secrets where indicated with: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Shared secret for signing outgoing webhook payloads (HMAC-SHA256).
# Generate: openssl rand -hex 32
# The server refuses to start silently with the default — it prints a loud
# warning at startup if this is not changed. Use a value ≥ 32 bytes of entropy.
WEBHOOK_SECRET=

# Public URL of the web inbox.
# Used to construct inbox_url values in API responses.
# Must match the scheme + domain Caddy serves the UI on.
BASE_URL=https://app.impri.dev

# ---------------------------------------------------------------------------
# Email for Let's Encrypt account (Caddy ACME)
# ---------------------------------------------------------------------------

# Caddy uses this address to register with Let's Encrypt and to receive
# expiry warnings. Does not need to match SMTP_FROM.
CADDY_ACME_EMAIL=admin@impri.dev

# ---------------------------------------------------------------------------
# Email notifications — AWS SES via SMTP
# ---------------------------------------------------------------------------
# Recommended: start on Resend free tier (3k/month) and migrate to SES at
# ~500 users (~50k emails/month). SES costs $0.10/1k vs Resend Scale $0.63/1k.
#
# AWS SES SMTP credentials (from IAM → SES → SMTP settings):
#   Host: email-smtp.<region>.amazonaws.com  (e.g. email-smtp.eu-west-1.amazonaws.com)
#   Port: 587, STARTTLS (SMTP_SECURE=false)
#   User/Pass: create an IAM SMTP credential pair in the SES console — NOT your
#   AWS access key. These are different credentials generated specifically for SMTP.
#
# Must also verify your sending domain (SPF + DKIM) and request production access
# to move out of SES sandbox (sandbox = only verified recipients).

SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
# Leave false for STARTTLS on port 587; set true only for implicit TLS on port 465.
SMTP_SECURE=false
# IAM SMTP username (looks like AKIA…)
SMTP_USER=
# IAM SMTP password (longer string, generated alongside the username)
SMTP_PASS=
# From address — must be verified in SES (domain or address level).
SMTP_FROM=impri@impri.dev
# Who receives notification emails (your address or a shared inbox).
NOTIFY_EMAIL=

# ---------------------------------------------------------------------------
# ntfy push notifications (recommended — free, no account needed on ntfy.sh)
# ---------------------------------------------------------------------------
# Install the ntfy app on your phone, subscribe to NTFY_TOPIC, and you get a
# push for every pending approval. Use a random hard-to-guess topic name — on
# ntfy.sh the topic name is the only access control (it acts as a shared secret).
#
# Generate a private topic: openssl rand -hex 16

NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# ---------------------------------------------------------------------------
# Stripe billing — optional; billing features are gated on these vars being set
# ---------------------------------------------------------------------------
# Get keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_…) during initial setup; swap to live keys to charge.

# Secret API key — server-side only, never expose to the browser.
STRIPE_SECRET_KEY=

# Webhook signing secret — obtained when you register the endpoint in Stripe:
#   Dashboard → Developers → Webhooks → Add endpoint
#   Endpoint URL: https://api.impri.dev/v1/billing/webhook
#   Events to listen: checkout.session.completed, customer.subscription.updated,
#                     customer.subscription.deleted, invoice.payment_failed
#   After saving, reveal the "Signing secret" (whsec_…) and paste here.
# Generate: copy from Stripe dashboard after creating the webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for your subscription products
# (Dashboard → Products → create "Impri Indie" + "Impri Team" → copy price IDs)
STRIPE_PRICE_INDIE=price_
STRIPE_PRICE_TEAM=price_

# ---------------------------------------------------------------------------
# Security — leave unset unless you know what you are doing
# ---------------------------------------------------------------------------

# Set to 1 ONLY on isolated intranet deployments where you control all clients.
# Bypasses the SSRF guard that blocks callback_url / watcher URLs resolving to
# private/RFC-1918/loopback addresses. Do NOT set on a public server.
# IMPRI_ALLOW_PRIVATE_TARGETS=

# Set to 1 to run in approval-inbox-only mode (disables watcher scheduler).
# DISABLE_WATCHER_SCHEDULER=
